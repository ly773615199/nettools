# NetTools 环境变量配置
# 复制此文件为 .env 并修改对应值

# ===== 服务器配置 =====
PORT=8000
NODE_ENV=production

# ===== 认证 =====
JWT_SECRET=change-me-to-a-random-string-in-production

# ===== 日志 =====
LOG_LEVEL=info                # debug | info | warn | error

# ===== Docker 部署 =====
FRONTEND_PORT=80              # 前端映射端口
BACKEND_PORT=8000             # 后端映射端口

# ===== 可选：Clash/Mihomo =====
# CLASH_BIN=/path/to/mihomo   # 自定义 mihomo 二进制路径

# ===== 可选：Bore 隧道服务器 =====
# BORE_BIN=/path/to/bore      # 自定义 bore 二进制路径
